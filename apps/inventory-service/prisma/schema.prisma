generator client {
    provider = "prisma-client-js"
    output   = "../../../node_modules/@prisma/inventory-client"
}

datasource db {
    provider = "mysql"
    url      = env("INVENTORY_DATABASE_URL")
}

model Inventory {
    productVariantId String                 @id
    quantity         Int                    @default(0)
    reservedQuantity Int                    @default(0)
    location         String?                @default("MAIN_WAREHOUSE")
    createdAt        DateTime               @default(now())
    updatedAt        DateTime               @updatedAt
    transactions     InventoryTransaction[]

    @@map("inventory")
}

model InventoryTransaction {
    id               String          @id @default(uuid())
    productVariantId String
    type             TransactionType
    quantityChange   Int
    quantityBefore   Int
    quantityAfter    Int
    referenceId      String?
    referenceType    ReferenceType
    note             String?         @db.Text
    createdBy        String
    createdAt        DateTime        @default(now())

    inventory Inventory @relation(fields: [productVariantId], references: [productVariantId], onDelete: Cascade)

    @@index([productVariantId])
    @@index([referenceId])
    @@map("inventory_transactions")
}

enum TransactionType {
    IN
    OUT
    RESERVE
    RELEASE
    COMMIT
    ADJUST
}

enum ReferenceType {
    ORDER
    RESTOCK
    MANUAL
    RETURN
}
