// ============================================================
// Cart Service — db_carts
// prisma/schema.prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client/cart"
}

datasource db {
  provider = "mysql"
  url      = env("CART_DATABASE_URL")
}

// ============================================================
// MODELS
// ============================================================

model Cart {
  id        String     @id @default(uuid()) @db.Char(36)
  userId    String     @unique @map("user_id") @db.Char(36)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  items     CartItem[]

  @@map("CARTS")
}

model CartItem {
  id          String  @id @default(uuid()) @db.Char(36)
  cartId      String  @map("cart_id") @db.Char(36)
  productId   String  @map("product_id") @db.Char(36)
  variantId   String? @map("variant_id") @db.Char(36)
  quantity    Int     @default(1)
  price       Decimal @db.Decimal(12, 2)   // Giá tại thời điểm thêm vào giỏ
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cart        Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@index([productId])
  @@index([variantId])
  @@map("CART_ITEMS")
}