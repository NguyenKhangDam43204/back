generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
}

model Review {
    id        String   @id @default(uuid()) @db.Char(36)
    userId    String   @map("user_id") @db.Char(36)
    productId String   @map("product_id") @db.Char(36)
    orderId   String   @map("order_id") @db.Char(36)
    rating    Int      @db.TinyInt
    content   String?  @db.Text
    isVisible Boolean  @default(true) @map("is_visible")
    createdAt DateTime @default(now()) @map("created_at")

    @@unique([userId, productId, orderId], map: "uq_reviews")
    @@index([productId], map: "idx_reviews_product")
    @@map("REVIEWS")
}

model Comment {
    id        String   @id @default(uuid()) @db.Char(36)
    productId String   @map("product_id") @db.Char(36)
    userId    String   @map("user_id") @db.Char(36)
    parentId  String?  @map("parent_id") @db.Char(36)
    content   String   @db.Text
    isVisible Boolean  @default(true) @map("is_visible")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

    parent   Comment?  @relation("CommentTree", fields: [parentId], references: [id])
    children Comment[] @relation("CommentTree")

    @@index([productId, parentId], map: "idx_comments_product")
    @@map("COMMENTS")
}
